{
    "name": "povly/moonshine-intervention-image",
    "description": "Image optimization and WebP/AVIF conversion field for MoonShine using intervention/image",
    "keywords": [
        "laravel",
        "moonshine",
        "image",
        "optimization",
        "webp",
        "avif",
        "intervention"
    ],
    "type": "library",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/povly/moonshine-intervention-image/issues",
        "source": "https://github.com/povly/moonshine-intervention-image"
    },
    "authors": [
        {
            "name": "Anatoly Porshnyov",
            "email": "povly19995@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "intervention/image": "^3.0",
        "intervention/image-laravel": "^1.0",
        "moonshine/moonshine": "^4.0",
        "yurizoom/moonshine-media-manager": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Povly\\MoonshineInterventionImage\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Povly\\MoonshineInterventionImage\\Tests\\": "tests/"
        }
    },
    "conflict": {
        "moonshine/moonshine": "<4.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Povly\\MoonshineInterventionImage\\Providers\\MoonshineInterventionImageServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
